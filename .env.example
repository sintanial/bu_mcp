# Copy to `.env` next to docker-compose.yml (optional).

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# BROWSER_USE_API_KEY=

# BU_MCP_DEFAULT_MAX_STEPS=100
# BU_MCP_DEFAULT_IDLE_TIMEOUT_SECONDS=900

# HTTP server (bu_mcp listens here; defaults shown):
# BU_MCP_HOST=127.0.0.1
# BU_MCP_PORT=8765
# BU_MCP_HTTP_PATH=/mcp
# BU_MCP_LOG_LEVEL=info
# BU_MCP_STATELESS_HTTP=false
# BU_MCP_JSON_RESPONSE=false
